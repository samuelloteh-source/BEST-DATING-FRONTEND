{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server/backend.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(signup|login|logout|verify/face|resend-verification|me|notifications|discover|matches|likes|messages|profile/gallery|api/.*|uploads/.*|health)$",
      "dest": "/server/backend.js"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ]
}
